# Database
DATABASE_URL=postgresql://intel:intel_secret@localhost:5432/intel_db

# OpenAI (required for AI summarization and name extraction)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# API server
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=your-crm-api-key-here

# Scraper settings
SCRAPE_SCHEDULE_ENABLED=true
SCRAPE_SCHEDULE_HOUR=6
SCRAPE_SCHEDULE_MINUTE=0
SCRAPE_TIMEZONE=America/Sitka
SCRAPE_INTERVAL_HOURS=24
USER_AGENT=IntelBot/1.0 (Newspaper Intelligence Scraper)

# Webhook for CRM push notifications (optional)
CRM_WEBHOOK_URL=
CRM_WEBHOOK_SECRET=
